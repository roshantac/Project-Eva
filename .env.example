# Server Configuration
PORT=3001
HOST=0.0.0.0
ENVIRONMENT=development

# Database Provider
# Options: 'mongodb' or 'file' (local JSON files)
DB_PROVIDER=file
FILE_DB_PATH=data

# LLM Provider Configuration
# Options: 'openai', 'ollama', 'lmstudio', 'groq', 'huggingface'
LLM_PROVIDER=ollama

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Ollama (Local LLM - FREE, OFFLINE)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_TIMEOUT=120

# LM Studio (Local - FREE)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# Groq (Cloud - FREE with limits)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Hugging Face (Cloud - FREE with limits)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Database
MONGODB_URI=mongodb://localhost:27017/eva-ai
REDIS_URL=redis://localhost:6379

# Weather API (Optional - https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Security
SESSION_SECRET=your_session_secret_here

# CORS
CLIENT_URL=http://localhost:5173

# Audio Provider Selection
# Options: openai, local, kokoro
AUDIO_PROVIDER=kokoro
AUDIO_ENABLED=true

# OpenAI Audio (Paid)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_WHISPER_MODEL=whisper-1

# Whisper.cpp (Local STT - FREE, OFFLINE)
WHISPER_CPP_PATH=/usr/local/bin/whisper-cli
WHISPER_MODEL=base.en
WHISPER_MODEL_PATH=/path/to/whisper-cpp/models

# Piper TTS (Local - OPTIONAL)
# PIPER_PATH=/usr/local/bin/piper
# PIPER_MODEL=en_US-lessac-medium
# PIPER_MODEL_PATH=/path/to/piper/models

# eSpeak TTS (Local - FREE, OFFLINE)
ESPEAK_PATH=/usr/local/bin/espeak
ESPEAK_ENABLED=true

MAX_AUDIO_DURATION=60000
AUDIO_SAMPLE_RATE=16000

# Kokoro-82M TTS (Local Python - Install: ./install-kokoro-local.sh)
# Set AUDIO_PROVIDER=kokoro for high-quality local TTS
KOKORO_LANG_CODE=a
KOKORO_DEFAULT_VOICE=af_heart
KOKORO_SAMPLE_RATE=24000

# Client-Side TTS (kokoro-js browser) - configure in client/.env
CLIENT_TTS_ENABLED=false

KEEP_TEMP_AUDIO=false

# Audio Emotion Detection (Python 3.12, venv-py312)
AUDIO_EMOTION_ENABLED=false
AUDIO_EMOTION_MODEL=ehcalabres/wav2vec2-lg-xlsr-en-speech-emotion-recognition

# Memory Settings
MAX_SHORT_TERM_MEMORY=20
AUTO_SAVE_MEMORY=true

# Conversation Logging
LOG_CONVERSATIONS=true
