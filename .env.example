# Server Configuration
PORT=3001
HOST=0.0.0.0
ENVIRONMENT=development

# Database Provider
# Options: 'mongodb' (requires MongoDB server) or 'file' (local JSON files, no setup needed)
DB_PROVIDER=file
FILE_DB_PATH=data

# LLM Provider Selection
# Options: openai, ollama, lmstudio, groq, huggingface
LLM_PROVIDER=ollama

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Ollama (Local LLM - FREE, OFFLINE)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# LM Studio (Local LLM - FREE, OFFLINE)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# Groq (Cloud LLM - FREE with rate limits)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Hugging Face (Cloud LLM - FREE with rate limits)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Audio Provider Selection
# Options: openai, local
AUDIO_PROVIDER=local

# OpenAI Audio (Paid)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_WHISPER_MODEL=whisper-1

# Whisper.cpp (Local STT - FREE, OFFLINE)
WHISPER_CPP_PATH=/usr/local/bin/whisper-cli
WHISPER_MODEL=base.en
WHISPER_MODEL_PATH=/Users/yourusername/.whisper-cpp/models

# Piper TTS (Local - FREE, OFFLINE)
PIPER_PATH=/usr/local/bin/piper
PIPER_MODEL=en_US-lessac-medium
PIPER_MODEL_PATH=/Users/yourusername/.local/share/piper/models

# eSpeak TTS (Fallback - FREE, OFFLINE)
ESPEAK_PATH=/usr/bin/espeak

# Audio Settings
AUDIO_ENABLED=true
MAX_AUDIO_DURATION=60000
AUDIO_SAMPLE_RATE=16000
KEEP_TEMP_AUDIO=false

# Audio Emotion Detection (wav2vec2)
AUDIO_EMOTION_ENABLED=true
AUDIO_EMOTION_MODEL=ehcalabres/wav2vec2-lg-xlsr-en-speech-emotion-recognition

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/eva-ai
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Security
SESSION_SECRET=your_session_secret_here
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Memory Settings
MAX_SHORT_TERM_MEMORY=20
AUTO_SAVE_MEMORY=true
LOG_CONVERSATIONS=true

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true
