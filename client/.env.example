# Client TTS Configuration Example
# Copy this file to .env and configure as needed

# TTS Provider Selection
# Options: 'server' (For Kokoro-82M local Python model, use 'server' (server handles TTS) or 'kokoro' (use client-side Kokoro TTS)
VITE_TTS_PROVIDER=server

# Kokoro TTS Settings (only used when VITE_TTS_PROVIDER=kokoro)
# Model: The Hugging Face model ID
VITE_KOKORO_MODEL=onnx-community/Kokoro-82M-v1.0-ONNX

# Dtype: Quantization level (affects quality and size)
# Options: "fp32" (best quality, largest), "fp16", "q8" (balanced), "q4" (fastest, smallest), "q4f16"
VITE_KOKORO_DTYPE=q8

# Device: Execution backend
# Options: "wasm" (universal), "webgpu" (faster, requires modern GPU), "cpu" (Node.js only)
# Note: If using "webgpu", recommend dtype="fp32" for best quality
VITE_KOKORO_DEVICE=wasm
