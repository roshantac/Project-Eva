    "frontend": "cd client && npm run dev",
    "test": "pytest",
    "format": "black app/",
    "lint": "flake8 app/"
  },
  "keywords": [
    "ai",
    "voice-assistant",
    "emotional-ai",
    "chatbot",
    "websocket",
    "fastapi",
    "python"
  ],
  "author": "Eva AI Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
