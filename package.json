{
  "name": "eva-ai-python",
  "version": "1.0.0",
  "description": "Eva AI - Emotional Voice Assistant (Python Edition)",
  "scripts": {
    "install": "./install.sh",
    "start": "./start.sh",
    "dev": "concurrently \"python run.py\" \"cd client && npm run dev\"",
